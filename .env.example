# Copy to .env (or .env.local) and fill in your Supabase project credentials.
# Without the Supabase vars, the app falls back to an in-memory demo-mode
# repository (see src/services/MockRepositories.ts) — useful for local dev, but
# with no cross-device realtime sync and no persistence across restarts.

# Browser-safe: used for reads + Realtime subscriptions (RLS read-only).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: used to write rows on behalf of unauthenticated users.
# NEVER expose this value to the browser or commit it to version control.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Single operator password for /admin (approve centros, manage the catalog).
# REQUIRED in production: the app refuses to fall back to a default there.
SUPER_ADMIN_PASSWORD=choose-a-strong-password

# Secret used to sign session cookies. Generate one with:
#   openssl rand -base64 32
# REQUIRED in production: the app refuses to sign sessions with the dev default.
SESSION_SECRET=generate-a-random-secret
